        "CLAUDE_PLUGIN_OPTION_PROVIDER_TIMEOUT_MS": "${CLAUDE_PLUGIN_OPTION_PROVIDER_TIMEOUT_MS}",
        "CLAUDE_PLUGIN_OPTION_MCP_TIMEOUT_MS": "${CLAUDE_PLUGIN_OPTION_MCP_TIMEOUT_MS}",
