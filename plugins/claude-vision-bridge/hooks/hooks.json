{
  "description": "Inject vision analysis context before user prompts are submitted.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/dist/hook-handler.js"],
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "claude-vision-bridge:mcp",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/dist/manual-mcp-command-handler.js"],
            "timeout": 120
          }
        ]
      }
    ]
  }
}
